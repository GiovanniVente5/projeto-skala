<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" prefHeight="700.0" prefWidth="700.0" spacing="24" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.projeto_skala.Controller.MenuController">
    <stylesheets>
        <URL value="@MenuView.css" />
    </stylesheets>
    <padding>
        <Insets bottom="48" left="64" right="64" top="48" />
    </padding>
    <Label styleClass="title" text="Skala Convertor" />
    <VBox fx:id="dropZone" alignment="CENTER" maxWidth="460.0" minHeight="220.0" spacing="12" styleClass="drop-zone">
        <Label styleClass="drop-zone-icon" text="XLS" />
        <Label styleClass="drop-zone-title" text="Drag and drop an Excel file here" />
        <Label styleClass="drop-zone-subtitle" text="or click to choose .xlsx, .xls, .xlsm, or .csv" />
        <Label fx:id="selectedFileLabel" styleClass="selected-file" text="No file selected" />
    </VBox>
    <HBox alignment="CENTER" maxWidth="460.0" spacing="12" styleClass="period-selector">
        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label styleClass="field-label" text="Mes" />
            <ComboBox fx:id="mesComboBox" maxWidth="Infinity" promptText="Mes" />
        </VBox>
        <VBox spacing="6">
            <Label styleClass="field-label" text="Ano" />
            <Spinner fx:id="anoSpinner" prefWidth="120.0" />
        </VBox>
    </HBox>
    <HBox alignment="CENTER" maxWidth="460.0" spacing="12" styleClass="menu-actions">
        <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#abrirTelaClientes" text="Cliente" HBox.hgrow="ALWAYS" />
        <Button disable="true" maxWidth="Infinity" mnemonicParsing="false" text="Relatorios" HBox.hgrow="ALWAYS" />
    </HBox>

</VBox>
